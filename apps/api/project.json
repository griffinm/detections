{
  "name": "api",
  "projectType": "application",
  "root": "apps/api",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run ruff check .", "cwd": "{projectRoot}" }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run ruff format .", "cwd": "{projectRoot}" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run mypy src/", "cwd": "{projectRoot}" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run pytest -q", "cwd": "{projectRoot}" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn api.main:app --reload --port 8000",
        "cwd": "{projectRoot}"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -c \"import json; from api.main import app; print(json.dumps(app.openapi()))\" > openapi.json",
        "cwd": "{projectRoot}"
      }
    }
  }
}
